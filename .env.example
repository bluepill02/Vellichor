# Create template file (this DOES get committed)
cat > .env.example << 'EOF'
# WordPress Site Configuration
WP_SITE_URL=https://your-site.com
WP_API_URL=https://your-site.com/wp-json/wp/v2
WP_USERNAME=your-username
WP_APP_PASSWORD=your-application-password

# Database (not needed for API-only access)
DB_HOST=localhost
DB_NAME=wordpress_local
DB_USER=root
DB_PASSWORD=

# Development Settings
WP_ENV=development
WP_DEBUG=true
EOF
